# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Never commit .env — it's already in .gitignore.

# ESPHome API encryption key from your device YAML (api.encryption.key)
ENCRYPTION_KEY=

# Device hostname or IP (optional, defaults to arbeitszimmer-display.local)
# DEVICE_HOST=192.168.1.100
